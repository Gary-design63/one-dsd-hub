{
  "name": "one-dsd-consultant-os",
  "version": "5.1.0",
  "description": "One DSD Consultant Operating System — Minnesota DHS Disability Services Division",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "client:install": "cd client && npm install",
    "client:build": "cd client && npm run build",
    "client:dev": "cd client && npm run dev",
    "postinstall": "if [ -d client ]; then cd client && npm install; fi"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1"
  }
}
