# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
# Supabase:  postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Railway:   Set automatically when you add a PostgreSQL service
# Render:    Set automatically when you add a PostgreSQL database
# Neon:      postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API key for AI features
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=change-this-to-a-strong-random-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your deployed frontend URL)
# ALLOWED_ORIGINS=https://one-dsd-cos.railway.app,https://your-custom-domain.com

# ─── Optional ─────────────────────────────────────────────────────────────────
# Directory for uploaded files (use /tmp for ephemeral cloud, or configure S3)
# UPLOAD_DIR=/tmp/uploads
