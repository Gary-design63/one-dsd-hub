# ─── Supabase (required) ──────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Anthropic / Claude AI (required for AI Agents page) ─────────────────────
# Get this from: console.anthropic.com → API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Microsoft Entra ID / Azure AD (optional — for production auth) ──────────
# Get these from: Azure Portal → Azure Active Directory → App registrations
# Required for Entra ID sign-in; omit for local dev with VITE_DEV_ADMIN=true
VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_TENANT_ID=your-azure-tenant-id

# ─── Local development ───────────────────────────────────────────────────────
# Set to "true" ONLY for local development to bypass auth with admin access.
# NEVER set this in production. The bypass only works on localhost regardless.
# VITE_DEV_ADMIN=true

# ─── CORS / Allowed Origins (Edge Functions) ─────────────────────────────────
# Comma-separated list of allowed origins for Edge Function CORS headers.
# Set in Supabase Edge Function secrets:
#   ALLOWED_ORIGINS=https://your-app.example.com,https://your-staging.example.com
# If not set, Edge Functions reject cross-origin requests (no wildcard).

# ─── Azure Blob Storage (optional — NOT active) ──────────────────────────────
# Azure Blob Storage integration is DISABLED by default.
# The blob-storage Edge Function always uses Supabase Storage as the backend.
# To enable Azure Blob in the future, implement proper Azure SDK auth (see
# blob-storage/index.ts for details) and set these in Supabase Edge Function secrets:
#   AZURE_STORAGE_ACCOUNT=<storage account name>
#   AZURE_STORAGE_KEY=<storage account key>
#   AZURE_STORAGE_CONTAINER=one-dsd-files

# ─── Cloud deployment notes ───────────────────────────────────────────────────
# Lovable:  set vars in Project → Settings → Environment Variables
# Azure SWA: set vars in Azure Portal → Static Web App → Configuration
# Netlify:  set vars in Site → Site configuration → Environment variables
# Vercel:   set vars in Project → Settings → Environment Variables
#
# NEVER commit .env or .env.local — this .env.example is safe to commit.
